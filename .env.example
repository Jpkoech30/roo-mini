# ═══════════════════════════════════════════════════════
# ROO-MINI — Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ── 🤖 AI Provider (required) ──
API_KEY=
# API_BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat

# ── 🐙 GitHub ──
# GITHUB_TOKEN=ghp_...

# ── 🔍 Google Search ──
# GOOGLE_API_KEY=AIza...
# GOOGLE_CSE_ID=...

# ── 🔐 Google Workspace (Gmail, Calendar, Drive) ──
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# ── 📋 Jira ──
# JIRA_HOST=mycompany.atlassian.net
# JIRA_EMAIL=user@company.com
# JIRA_API_TOKEN=...

# ── 💬 Slack ──
# SLACK_TOKEN=xoxb-...

# ── 🐘 PostgreSQL ──
# PG_URL=postgresql://user:pass@localhost:5432/db

# ── ⚙️ Advanced ──
# API_TIMEOUT=60000
# MAX_ITERATIONS=50
# MAX_RETRIES=5
# TYPEWRITER_SPEED=12
# TOOL_RESULT_MAX_CHARS=500
