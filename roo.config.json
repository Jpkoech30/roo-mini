{
  "version": "1.0.0",
  "name": "roo-mini",
  "model": "gpt-4o",
  "mode": "auto",
  "mcpServers": {
    "github": {
      "command": "node",
      "args": ["src/mcp/servers/github.mjs"],
      "env": { "GITHUB_TOKEN": "${GITHUB_TOKEN}" }
    },
    "postgres": {
      "command": "node",
      "args": ["src/mcp/servers/postgres.mjs"],
      "env": { "PG_URL": "${PG_URL}" }
    }
  },
  "memory": {
    "enabled": true,
    "maxConversations": 50
  },
  "costTracking": {
    "enabled": true,
    "budget": 10.00
  }
}
